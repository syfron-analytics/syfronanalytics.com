---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contacto — Syfron Analytics">
  <Navbar />

  <section class="pt-32 pb-24">
    <div class="max-w-4xl mx-auto px-6 text-center relative">
      <div class="absolute top-0 left-1/2 w-96 h-96 bg-emerald-500/5 rounded-full blur-3xl -z-10 -translate-x-1/2"></div>
      <div class="absolute bottom-0 right-0 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl -z-10"></div>

      <span class="inline-block text-xs font-mono text-purple-400 bg-purple-500/10 px-3 py-1 rounded-full mb-6 uppercase tracking-wider">Contact</span>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4" data-i18n="contact.title" data-animate>Hablemos</h1>
      <p class="text-dark-400 mb-12 text-lg" data-i18n="contact.subtitle" data-animate>¿Trabajas en algo complejo o poco definido? Hablemos.</p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-6" data-animate>
        <a href="mailto:contact@syfronanalytics.com" class="inline-flex items-center gap-3 px-8 py-4 bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl font-medium transition shadow-lg shadow-emerald-600/20">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          <span data-i18n="contact.cta">Escríbenos</span>
        </a>
        <a href="https://linkedin.com/in/enrique-r-sebastian" target="_blank" rel="noopener" class="inline-flex items-center gap-3 px-8 py-4 border border-dark-600 hover:border-emerald-500 text-dark-200 rounded-xl font-medium transition">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>
      <p class="text-dark-500 text-sm mt-6">
        <button id="copy-email" class="hover:text-emerald-400 transition cursor-pointer underline decoration-dark-600 underline-offset-4">contact@syfronanalytics.com</button>
        <span id="copy-feedback" class="text-emerald-400 text-xs ml-2 opacity-0 transition-opacity duration-300"></span>
      </p>
      <script is:inline>
        document.addEventListener('astro:page-load', function() {
          var btn = document.getElementById('copy-email');
          var fb = document.getElementById('copy-feedback');
          if (!btn || !fb) return;
          btn.addEventListener('click', function() {
            var email = 'contact@syfronanalytics.com';
            if (navigator.clipboard && window.isSecureContext) {
              navigator.clipboard.writeText(email).then(show);
            } else {
              var ta = document.createElement('textarea');
              ta.value = email;
              ta.style.position = 'fixed';
              ta.style.opacity = '0';
              document.body.appendChild(ta);
              ta.select();
              document.execCommand('copy');
              document.body.removeChild(ta);
              show();
            }
            function show() {
              fb.textContent = '✓ Copiado';
              fb.style.opacity = '1';
              setTimeout(function() { fb.style.opacity = '0'; }, 2000);
            }
          });
        });
      </script>
      <p class="text-dark-500 text-xs mt-4" data-i18n="contact.hint" data-animate>Describe brevemente tu problema y contexto. Responderemos si encaja con lo que hacemos.</p>
    </div>
  </section>

  <Footer />
</Layout>
