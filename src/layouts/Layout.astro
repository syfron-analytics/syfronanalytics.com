---
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  lang?: string;
}

const { title, lang = 'es' } = Astro.props;
---

<!doctype html>
<html lang={lang} class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Syfron Analytics — Data Science, IA y consultoría estadística." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&family=JetBrains+Mono:ital,wght@0,400;0,500;1,700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <ViewTransitions />
    <style>
      /* Fade-in on scroll */
      [data-animate] {
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 0.6s ease-out, transform 0.6s ease-out;
      }
      [data-animate].is-visible {
        opacity: 1;
        transform: translateY(0);
      }
      /* Stagger children */
      [data-animate-delay="1"] { transition-delay: 0.1s; }
      [data-animate-delay="2"] { transition-delay: 0.2s; }
      [data-animate-delay="3"] { transition-delay: 0.3s; }

      /* Enhanced hover for service cards */
      .service-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
      }
      .service-card:hover {
        transform: scale(1.03);
        box-shadow: 0 0 20px rgba(16, 185, 129, 0.15), 0 0 40px rgba(16, 185, 129, 0.05);
        border-color: rgba(16, 185, 129, 0.5) !important;
      }
      .service-card:hover .icon-container {
        filter: brightness(1.3);
      }

    </style>
  </head>
  <body class="bg-dark-950 text-dark-200 font-sans antialiased min-h-screen flex flex-col">
    <slot />
    <!-- Scroll animations -->
    <script is:inline>
      (function() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              observer.unobserve(e.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        function observe() {
          document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));
        }
        document.addEventListener('astro:page-load', observe);
      })();
    </script>

    <!-- Counter animation -->
    <script is:inline>
      (function() {
        function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

        function animateCounter(el) {
          var target = parseInt(el.getAttribute('data-count-to'), 10);
          var suffix = el.getAttribute('data-count-suffix') || '';
          var duration = 2000;
          var start = performance.now();
          function tick(now) {
            var t = Math.min((now - start) / duration, 1);
            var val = Math.round(easeOut(t) * target);
            el.textContent = val.toLocaleString('es-ES') + suffix;
            if (t < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
        }

        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting) {
              animateCounter(e.target);
              observer.unobserve(e.target);
            }
          });
        }, { threshold: 0.5 });

        function init() {
          document.querySelectorAll('[data-count-to]').forEach(function(el) {
            observer.observe(el);
          });
        }
        document.addEventListener('astro:page-load', init);
      })();
    </script>

    <!-- Particle constellation -->
    <script is:inline>
      function initParticles() {
        var canvas = document.getElementById('particle-canvas');
        if (!canvas) return;
        // Cancel any previous animation
        if (window._particleAnimId) cancelAnimationFrame(window._particleAnimId);
        var ctx = canvas.getContext('2d');
        var particles = [];
        var PARTICLE_COUNT = 90;
        var CONNECT_DIST = 250;
        var colors = ['16,185,129', '139,92,246']; // emerald, purple
        var animId;

        // Seeded PRNG (mulberry32) — same graph every time
        var _seed = 42;
        function seededRandom() {
          _seed = (_seed + 0x6D2B79F5) | 0;
          var t = Math.imul(_seed ^ (_seed >>> 15), 1 | _seed);
          t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
          return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
        }

        function resize() {
          var rect = canvas.parentElement.getBoundingClientRect();
          canvas.width = rect.width;
          canvas.height = rect.height;
        }

        function init() {
          resize();
          particles = [];
          _seed = 42; // reset seed so layout is always the same
          var cx = canvas.width / 2;
          var cy = canvas.height / 2;
          var spreadX = canvas.width * 0.45;
          var spreadY = canvas.height * 0.45;
          for (var i = 0; i < PARTICLE_COUNT; i++) {
            var angle = seededRandom() * Math.PI * 2;
            var radius = seededRandom() * 0.8 + 0.2;
            particles.push({
              x: cx + Math.cos(angle) * radius * spreadX * (0.5 + seededRandom() * 0.5),
              y: cy + Math.sin(angle) * radius * spreadY * (0.5 + seededRandom() * 0.5),
              vx: (seededRandom() - 0.5) * 0.25,
              vy: (seededRandom() - 0.5) * 0.25,
              r: seededRandom() * 3 + 1.5,
              color: colors[Math.floor(seededRandom() * colors.length)],
              homeX: 0, homeY: 0
            });
            particles[i].homeX = particles[i].x;
            particles[i].homeY = particles[i].y;
          }
        }

        function draw() {
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          // Lines
          for (var i = 0; i < particles.length; i++) {
            for (var j = i + 1; j < particles.length; j++) {
              var dx = particles[i].x - particles[j].x;
              var dy = particles[i].y - particles[j].y;
              var dist = Math.sqrt(dx * dx + dy * dy);
              if (dist < CONNECT_DIST) {
                var alpha = (1 - dist / CONNECT_DIST) * 0.2;
                ctx.strokeStyle = 'rgba(' + particles[i].color + ',' + alpha + ')';
                ctx.lineWidth = 0.8;
                ctx.beginPath();
                ctx.moveTo(particles[i].x, particles[i].y);
                ctx.lineTo(particles[j].x, particles[j].y);
                ctx.stroke();
              }
            }
          }
          // Dots
          for (var i = 0; i < particles.length; i++) {
            var p = particles[i];
            ctx.fillStyle = 'rgba(' + p.color + ',0.35)';
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
            ctx.fill();
            // Move with gentle pull back to home
            p.x += p.vx;
            p.y += p.vy;
            // Soft spring back toward home position
            p.vx += (p.homeX - p.x) * 0.0005;
            p.vy += (p.homeY - p.y) * 0.0005;
            // Light damping
            p.vx *= 0.999;
            p.vy *= 0.999;
          }
          window._particleAnimId = requestAnimationFrame(draw);
        }

        var resizeTimeout;
        window.addEventListener('resize', function() {
          clearTimeout(resizeTimeout);
          resizeTimeout = setTimeout(function() {
            init();
          }, 200);
        });

        init(); draw();
      }
      // Run on first load and on every View Transition navigation
      document.addEventListener('astro:page-load', initParticles);
    </script>

    <!-- i18n Script -->
    <script is:inline>
      const TRANSLATIONS_KEY = '__syfron_translations';
      
      function getNestedValue(obj, path) {
        return path.split('.').reduce((o, k) => o && o[k], obj);
      }

      function getLang() {
        return localStorage.getItem('syfron-lang') || (navigator.language.startsWith('es') ? 'es' : 'en');
      }

      function setLang(lang) {
        localStorage.setItem('syfron-lang', lang);
        applyLang(lang);
      }

      function applyLang(lang) {
        const t = window[TRANSLATIONS_KEY];
        if (!t) return;
        const strings = t[lang];

        document.querySelectorAll('[data-i18n]').forEach(el => {
          const key = el.getAttribute('data-i18n');
          const value = getNestedValue(strings, key);
          if (value && typeof value === 'string') {
            // Check if element has child elements to preserve (svg, span icons)
            const hasChildElements = el.querySelector('svg, img');
            if (hasChildElements) {
              // Replace only text nodes
              Array.from(el.childNodes).forEach(n => {
                if (n.nodeType === 3 && n.textContent.trim()) n.textContent = value;
              });
            } else {
              el.textContent = value;
            }
          }
        });

        // Update list items
        document.querySelectorAll('[data-i18n-list]').forEach(el => {
          const key = el.getAttribute('data-i18n-list');
          const items = getNestedValue(strings, key);
          if (Array.isArray(items)) {
            el.innerHTML = items.map(item => 
              `<li class="text-sm text-dark-400 flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>${item}</li>`
            ).join('');
          }
        });

        // Update stats
        const stats = getNestedValue(strings, 'portfolio.case.stats');
        if (stats) {
          document.querySelectorAll('[data-i18n-stat]').forEach(el => {
            const attr = el.getAttribute('data-i18n-stat');
            const [idx, field] = attr.split('-');
            const stat = stats[parseInt(idx)];
            if (stat) {
              if (field === 'value') el.textContent = stat.value;
              else if (field === 'label') el.textContent = stat.label;
            }
          });
        }

        // Update toggle buttons
        document.querySelectorAll('.lang-toggle').forEach(btn => {
          btn.textContent = lang === 'es' ? 'EN' : 'ES';
        });
        document.documentElement.lang = lang;
      }

      // Init on page load and View Transitions
      document.addEventListener('astro:page-load', () => {
        const lang = getLang();
        applyLang(lang);

        document.querySelectorAll('.lang-toggle').forEach(btn => {
          btn.addEventListener('click', () => {
            const current = getLang();
            setLang(current === 'es' ? 'en' : 'es');
          });
        });

        // Mobile menu
        const menuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        if (menuBtn && mobileMenu) {
          menuBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
          });
        }
      });
    </script>
  </body>
</html>
